{
  "rules": {
    "games": {
      "$gameId": {
        ".read": "auth != null",
        ".write": false
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": false,
        "games": {
          ".indexOn": ".value"
        }
      }
    },
    "invitations": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    },
    "followNotifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": false
      }
    }
  }
}
